<article class="message message-{{ message.source }} rounded-lg border border-border px-4 py-3 shadow-sm">
  <header class="flex items-center justify-between gap-3 text-xs">
    <span class="font-medium text-muted">{{ "You" if message.source == "human" else "Barista" }}</span>
    {% if message.source == "ai" and intent_detected %}
      <span class="rounded-full bg-accent-soft px-2 py-0.5 text-[11px] text-accent-strong">{{ intent_detected }}</span>
    {% endif %}
  </header>
  <p class="mt-2 whitespace-pre-wrap text-base text-strong">{{ message.message }}</p>
  {% if message.source == "ai" and metrics_badges is defined %}
    <footer class="mt-3 flex flex-wrap items-center gap-1.5 text-[11px]">
      {% if metrics_badges.intent %}
        <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-surface-strong/55 px-2 py-0.5 text-muted" title="Intent: {{ metrics_badges.intent }}">
          <span class="grid h-4 w-4 place-items-center rounded-full bg-surface text-[10px] font-semibold text-accent-strong" aria-hidden="true">I</span>
          {{ metrics_badges.intent }}
        </span>
      {% endif %}
      {% if metrics_badges.vector_query %}
        <span class="inline-flex min-w-0 items-center gap-1.5 rounded-full border border-border bg-surface-strong/55 px-2 py-0.5 text-muted" title="Vector query: {{ metrics_badges.vector_query }}">
          <span class="grid h-4 w-4 shrink-0 place-items-center rounded-full bg-surface text-[10px] font-semibold text-accent-strong" aria-hidden="true">Q</span>
          <span class="truncate">&ldquo;{{ metrics_badges.vector_query }}&rdquo;</span>
        </span>
      {% endif %}
      {% if metrics_badges.total_ms is not none %}
        <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-surface-strong/55 px-2 py-0.5 text-muted" title="Total response: {{ metrics_badges.total_ms }} ms">
          <span class="grid h-4 w-4 place-items-center rounded-full bg-surface text-[10px] font-semibold text-accent-strong" aria-hidden="true">T</span>
          {{ metrics_badges.total_ms }} ms
        </span>
      {% endif %}
      {% if metrics_badges.embedding_ms is not none %}
        <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-surface-strong/55 px-2 py-0.5 text-muted" title="Embedding phase: {{ metrics_badges.embedding_ms }} ms">
          <span class="grid h-4 w-4 place-items-center rounded-full bg-surface text-[10px] font-semibold text-accent-strong" aria-hidden="true">E</span>
          {{ metrics_badges.embedding_ms }} ms
        </span>
      {% endif %}
      {% if metrics_badges.oracle_ms is not none %}
        <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-surface-strong/55 px-2 py-0.5 text-muted" title="Oracle vector phase: {{ metrics_badges.oracle_ms }} ms">
          <span class="grid h-4 w-4 place-items-center rounded-full bg-surface text-[10px] font-semibold text-accent-strong" aria-hidden="true">O</span>
          {{ metrics_badges.oracle_ms }} ms
        </span>
      {% endif %}
      {% if metrics_badges.embedding_cache_hit %}
        <span class="inline-flex items-center gap-1.5 rounded-full border border-success/25 bg-success/10 px-2 py-0.5 text-success" title="Embedding cache: hit">
          <span class="grid h-4 w-4 place-items-center rounded-full bg-surface text-[10px] font-semibold text-accent-strong" aria-hidden="true">E</span>
          embedding cache hit
        </span>
      {% endif %}
      {% if metrics_badges.from_cache %}
        <span class="inline-flex items-center gap-1.5 rounded-full border border-success/25 bg-success/10 px-2 py-0.5 text-success" title="Response cache: hit">
          <span class="grid h-4 w-4 place-items-center rounded-full bg-surface text-[10px] font-semibold text-accent-strong" aria-hidden="true">R</span>
          response cache hit
        </span>
      {% endif %}
    </footer>
  {% endif %}
</article>
