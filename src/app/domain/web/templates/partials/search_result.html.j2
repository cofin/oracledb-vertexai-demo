{# Single ProductMatch row for the explore-page Panel 1 list. #}
<article class="flex items-start justify-between gap-4 rounded-lg border border-border bg-surface px-3 py-2">
  <div class="min-w-0">
    <h4 class="truncate text-sm font-semibold text-strong">{{ match.name }}</h4>
    <p class="truncate text-xs text-muted">{{ match.description }}</p>
  </div>
  <div class="flex shrink-0 flex-col items-end gap-1 text-xs">
    <span class="font-mono text-strong">${{ '%.2f' % match.price }}</span>
    <span class="rounded-full bg-accent-soft px-2 py-0.5 text-accent-strong">{{ '%.1f' % match.similarity }}%</span>
  </div>
</article>
