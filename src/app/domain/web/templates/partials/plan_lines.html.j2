{# Oracle EXPLAIN PLAN viewer rendered for the explore-page Panel 2. #}
<div id="plan"{% if plan_oob | default(false) %} hx-swap-oob="outerHTML"{% endif %} class="mt-3 space-y-3">
  {% if plan is defined and plan %}
    {% if plan.plan_summary == "Plan unavailable" %}
      <p class="rounded-lg border border-danger/40 bg-danger/10 px-3 py-2 text-xs text-danger" role="alert">
        {{ plan.plan_lines[0] if plan.plan_lines else "Plan unavailable." }}
      </p>
    {% else %}
      <p class="text-xs text-muted">
        Top vector op: <span class="font-mono text-accent-strong">{{ plan.plan_summary or '—' }}</span>
      </p>

      {% if plan.plan_rows %}
        <div class="rounded-lg border border-border bg-surface">
          <table class="w-full table-fixed text-left text-xs">
            <colgroup>
              <col class="w-10">
              <col>
              <col class="w-24">
              <col class="w-16">
              <col class="w-20">
              <col class="w-20">
            </colgroup>
            <thead class="bg-surface-strong text-muted">
              <tr>
                <th class="px-3 py-2 font-semibold">Id</th>
                <th class="px-3 py-2 font-semibold">Operation</th>
                <th class="px-3 py-2 font-semibold">Name</th>
                <th class="px-3 py-2 text-right font-semibold">Rows</th>
                <th class="px-3 py-2 text-right font-semibold">Cost</th>
                <th class="px-3 py-2 text-right font-semibold">Time</th>
              </tr>
            </thead>
            <tbody>
              {% for row in plan.plan_rows %}
                <tr data-plan-row class="border-t border-border {% if row.is_vector %}bg-accent-soft/60 text-accent-strong{% else %}text-strong{% endif %}">
                  <td class="px-3 py-2 font-mono">{{ row.id }}</td>
                  <td class="break-words px-3 py-2 font-medium">{{ row.operation }}</td>
                  <td class="break-words px-3 py-2 font-mono text-muted">{{ row.name or '—' }}</td>
                  <td class="px-3 py-2 text-right font-mono text-muted">{{ row.rows or '—' }}</td>
                  <td class="break-words px-3 py-2 text-right font-mono text-muted">{{ row.cost or '—' }}</td>
                  <td class="break-words px-3 py-2 text-right font-mono text-muted">{{ row.time or '—' }}</td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% endif %}

      <details class="rounded-lg border border-border bg-deep">
        <summary class="cursor-pointer px-3 py-2 text-xs font-semibold text-muted">Raw DBMS_XPLAN output</summary>
        <pre data-plan-line class="max-h-64 overflow-auto border-t border-border p-3 font-mono text-xs leading-relaxed text-surface">{% for line in plan.plan_lines %}{{ line }}
{% endfor %}</pre>
      </details>
    {% endif %}
  {% else %}
    <p class="rounded-lg border border-dashed border-border bg-surface px-3 py-2 text-xs text-muted">
      Search the menu to view the Oracle execution plan.
    </p>
  {% endif %}
</div>
