<!DOCTYPE html>
<html lang="en" class="bg-canvas">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <title>{% block title %}Cymbal Coffee{% endblock %}</title>
    <link rel="icon" href="/favicon.ico" sizes="any">
    {{ vite_hmr() | safe }}
    {{ vite('src/resources/main.js') | safe }}
  </head>
  <body hx-ext="litestar" class="min-h-screen bg-canvas text-base font-sans antialiased">
    {% include "_nav.html.j2" %}
    {% include "partials/_flash.html.j2" %}
    <main class="mx-auto max-w-5xl px-4 py-6">
      {% block content %}{% endblock %}
    </main>
  </body>
</html>
