{% extends "base.html.j2" %}

{% block title %}Cymbal Coffee — Barista Chat{% endblock %}

{% block content %}
  <section
    x-data="{
      persona: 'enthusiast',
      sessionId: localStorage.getItem('cc-sid') ?? (() => { const s = crypto.randomUUID(); localStorage.setItem('cc-sid', s); return s; })()
    }"
    class="space-y-4"
  >
    <header class="flex items-center justify-between gap-4">
      <h1 class="text-xl font-semibold text-strong">Talk to a barista</h1>
      <div role="radiogroup" class="inline-flex rounded-full border border-border bg-surface p-0.5 text-xs">
        <template x-for="value in ['novice', 'enthusiast', 'expert', 'barista']" :key="value">
          <button
            type="button"
            x-text="value"
            @click="persona = value"
            :class="persona === value ? 'bg-accent-soft text-accent-strong' : 'text-muted hover:text-strong'"
            class="rounded-full px-3 py-1 capitalize transition-colors"
          ></button>
        </template>
      </div>
    </header>

    <div id="metrics-badges" class="flex flex-wrap items-center gap-2 text-xs"></div>

    <div id="messages" class="space-y-3"></div>

    <div id="chat-error"></div>

    <form
      hx-post="/api/chat"
      hx-target="#messages"
      hx-swap="beforeend"
      hx-headers='js:{ "X-Session-Id": sessionId }'
      hx-include="[name=persona]"
      hx-on::after-request="if (event.detail.successful) this.reset()"
      class="flex items-stretch gap-2 rounded-xl border border-border bg-surface p-2"
    >
      <input type="hidden" name="persona" :value="persona">
      <input
        type="text"
        name="message"
        autocomplete="off"
        required
        placeholder="Recommend me a coffee…"
        class="flex-1 rounded-lg bg-deep px-3 py-2 text-base text-strong placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent-strong"
      >
      <button
        type="submit"
        class="rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-strong transition-colors hover:bg-accent-strong"
      >Send</button>
    </form>
  </section>
{% endblock %}
