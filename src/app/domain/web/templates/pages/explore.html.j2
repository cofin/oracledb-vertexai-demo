{% extends "base.html.j2" %}

{% block title %}Cymbal Coffee — Explore{% endblock %}
{% block page_kicker %}Oracle 26ai Lab{% endblock %}
{% block page_heading %}Performance dashboard{% endblock %}
{% block page_subheading %}Vector search, EXPLAIN PLAN, and live service telemetry{% endblock %}

{% block content %}
<section class="space-y-6">
  <header class="flex items-center justify-between gap-4">
    <h1 class="text-xl font-semibold text-strong">Vector explore</h1>
    <p class="text-xs text-muted">Live Oracle 26ai + Vertex AI instrumentation</p>
  </header>

  <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
    {# Panel 1: live vector search — server partial via HTMX #}
    <section id="panel-vector-search" data-ui-panel="vector-search" class="ui-panel p-4">
      <h2 class="mb-2 text-sm font-semibold text-strong">1 · Vector search</h2>
      <input type="search" name="query" value="{{ query }}" placeholder="dark ethiopian pour-over" autocomplete="off"
        class="w-full rounded-lg bg-deep px-3 py-2 text-sm text-strong placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent-strong"
        hx-post="/api/vector-demo" hx-trigger="keyup changed delay:300ms" hx-target="#search-results" hx-include="this">
      <div id="search-results" class="mt-3 space-y-2"></div>
    </section>

    {# Panel 2: EXPLAIN PLAN viewer — server partial via HTMX #}
    <section id="panel-explain-plan" data-ui-panel="explain-plan" class="ui-panel p-4">
      <h2 class="mb-2 text-sm font-semibold text-strong">2 · EXPLAIN PLAN viewer</h2>
      <input type="search" name="query" value="{{ query }}" placeholder="dark ethiopian pour-over" autocomplete="off"
        class="w-full rounded-lg bg-deep px-3 py-2 text-sm text-strong placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-accent-strong"
        hx-get="/api/explain-plan" hx-trigger="keyup changed delay:500ms" hx-target="#plan" hx-swap="json">
      <div id="plan" class="mt-3">
        <template ls-if="planSummary">
          <p class="text-xs text-muted">
            Top vector op: <span class="font-mono text-accent-strong">${planSummary}</span>
          </p>
          <pre
            class="mt-2 max-h-64 overflow-auto rounded-lg border border-border bg-deep p-3 font-mono text-xs leading-relaxed text-base">
              <template ls-for="line in planLines">${line}
</template>
            </pre>
        </template>
        <template ls-else>
          <p class="text-xs text-muted">Type to see the plan.</p>
        </template>
      </div>
    </section>

    {# Panel 3: metrics summary cards — client-side ls-for templating #}
    <section id="panel-metrics-summary" data-ui-panel="metrics-summary" class="ui-panel p-4">
      <h2 class="mb-2 text-sm font-semibold text-strong">3 · Metrics summary</h2>
      <div id="metrics-summary" class="grid grid-cols-2 gap-3" hx-get="/api/metrics/summary"
        hx-trigger="load, every 10s" hx-swap="json">
        <template ls-for="card in $data.cards" ls-key="card.label">
          <article data-metric-card class="metric-card px-3 py-2">
            <p class="text-xs text-muted">${card.label}</p>
            <p class="text-base font-semibold text-strong">${card.value}</p>
            <p :class="card.trend === 'up' ? 'text-success' : card.trend === 'down' ? 'text-danger' : 'text-muted'"
              class="text-xs">${card.trendValue ?? card.trend}</p>
          </article>
        </template>
      </div>
    </section>

    {# Panel 4: latency time-series — Alpine + ApexCharts #}
    <section id="panel-latency-chart" data-ui-panel="latency-chart" class="ui-panel p-4">
      <h2 class="mb-2 text-sm font-semibold text-strong">4 · Latency time-series</h2>
      <div data-chart-host="latency" x-data="latencyChart()" x-init="init()" x-ref="latencyHost"
        class="chart-host h-64 w-full"></div>
    </section>

    <section id="panel-classify-compare" data-ui-panel="classify-compare" class="ui-panel p-4 lg:col-span-2">
      <div class="flex flex-wrap items-start justify-between gap-3">
        <div>
          <h2 class="mb-1 text-sm font-semibold text-strong">5 · Classify compare</h2>
          <p class="text-xs text-muted">Ground-truth intent labels compared against live classification output.</p>
        </div>
        <span class="telemetry-chip border-border bg-surface-strong/55 text-muted">offline eval</span>
      </div>
      <div x-data="classifyComparePanel()" x-init="init()" class="mt-4">
        <div x-show="missing" x-cloak class="rounded-lg border border-border bg-surface-strong/60 p-3 text-sm text-muted">
          <p class="font-medium text-strong">Classify compare data is not available yet.</p>
          <p class="mt-1" x-text="hint"></p>
        </div>
        <div x-show="available" x-cloak class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_18rem]">
          <div data-chart-host="classify-compare" x-ref="classifyHost" class="chart-host h-72 w-full"></div>
          <div class="rounded-lg border border-border bg-surface-strong/50 p-3">
            <p class="text-xs font-semibold uppercase text-muted">Rows</p>
            <p class="mt-1 text-2xl font-semibold text-strong" x-text="rows.length"></p>
            <p class="mt-3 text-xs text-muted">Gold labels, legacy labels, and new classifier labels are counted per intent.</p>
          </div>
        </div>
      </div>
    </section>
  </div>
  <div data-ui-popover-root="explore" class="popover-surface sr-only" aria-hidden="true"></div>
</section>

<script>
  function latencyChart() {
    return {
      chart: null,
      async init() {
        const data = await fetch('/api/metrics/charts').then((r) => r.json())
        this.chart = new ApexCharts(this.$refs.latencyHost, {
          chart: { type: 'line', height: 256, foreColor: '#a1a1aa', toolbar: { show: false } },
          stroke: { curve: 'smooth', width: 2 },
          xaxis: { categories: data.labels },
          theme: { mode: 'dark' },
          colors: ['#ca8a04', '#4ade80', '#60a5fa'],
          series: [
            { name: 'Total ms', data: data.series.totalMs },
            { name: 'Oracle ms', data: data.series.oracleMs },
            { name: 'Embedding ms', data: data.series.embeddingMs },
          ],
        })
        this.chart.render()
      },
    }
  }

  function classifyComparePanel() {
    return {
      available: false,
      missing: false,
      hint: '',
      rows: [],
      chart: null,
      async init() {
        const response = await fetch('/api/classify-compare')
        const data = await response.json()
        this.available = Boolean(data.available)
        this.missing = !this.available
        this.hint = data.hint ?? 'Run the classify-compare command to generate the dataset.'
        this.rows = Array.isArray(data.rows) ? data.rows : []
        if (!this.available) {
          return
        }
        const intents = [...new Set(this.rows.flatMap((row) => [row.gold, row.legacy, row.new]).filter(Boolean))]
        const countFor = (field, intent) => this.rows.filter((row) => row[field] === intent).length
        this.chart = new ApexCharts(this.$refs.classifyHost, {
          chart: { type: 'bar', height: 288, foreColor: '#77675f', toolbar: { show: false } },
          plotOptions: { bar: { borderRadius: 3, columnWidth: '62%' } },
          xaxis: { categories: intents },
          colors: ['#6f8064', '#8f5f43', '#587487'],
          series: [
            { name: 'Gold', data: intents.map((intent) => countFor('gold', intent)) },
            { name: 'Legacy', data: intents.map((intent) => countFor('legacy', intent)) },
            { name: 'New', data: intents.map((intent) => countFor('new', intent)) },
          ],
        })
        this.chart.render()
      },
    }
  }
  </script>
{% endblock %}
